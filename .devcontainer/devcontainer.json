{
  "name": "Warsztat: Podgląd NAV funduszu",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": { "label": "Aplikacja (API + frontend)", "onAutoForward": "openbrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-mssql.mssql"
      ]
    }
  },
  "remoteEnv": {
    "DB_HOST": "db",
    "DB_PORT": "1433",
    "DB_NAME": "baseFunds",
    "DB_USER": "workshop_reader",
    "DB_PASSWORD": "Workshop!Reader1",
    "PORT": "3000"
  },
  "postCreateCommand": "echo 'Środowisko gotowe. Baza funduszy wstaje w tle (~30-60 s). Patrz .devcontainer/README.md'"
}
