{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 .github/scripts/safety_guard.py",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "python3 .github/scripts/code_diagnostics.py",
        "timeout": 10
      }
    ]
  }
}
